# Local development — point to the credentials file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials.json

# Shared app access token — required in production
API_TOKEN=replace-with-a-long-random-token

# Production (Vercel) — paste the full credentials.json content as a JSON string
# The server also accepts the same JSON base64-encoded for backward compatibility.
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

SPREADSHEET_ID=your-spreadsheet-id-here
DEFAULT_CURRENCY=TWD
PORT=3003
